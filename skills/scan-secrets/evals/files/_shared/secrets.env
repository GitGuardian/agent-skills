# Synthetic credential strings used by the scan-secrets eval fixtures.
#
# These are real-shape values that ggshield's detectors will flag if it
# scans them — that is the entire point: the runtime fixtures need to
# trigger detections so the evals can grade what the agent does with them.
#
# In *this* file, each line carries a `# ggignore` comment, which tells
# ggshield to suppress the detection during repo-wide scans (CI, local
# pre-commit checks). When `setup.sh` materializes a fixture, it sources
# this file (variable assignments only) and writes the values into target
# files WITHOUT the ggignore comment — so the runtime fixture triggers
# detections as intended.
#
# None of these credentials are real. They match GitGuardian's detector
# patterns but `ggshield secret scan` reports them as Validity: Invalid.

# AWS — synthetic IAM access key pair (matches AKIA[0-9A-Z]{16} format)
LEAKY_AWS_KEY="AKIA2EXAMPLE7BVZSF6X" # ggignore: synthetic eval fixture
LEAKY_AWS_SECRET="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" # ggignore: synthetic eval fixture

# GitHub — synthetic classic personal access token (ghp_ + 36 chars)
LEAKY_GITHUB_PAT="ghp_aB1cD2eF3gH4iJ5kL6mN7oP8qR9sT0uV1wXy" # ggignore: synthetic eval fixture

# Stripe — synthetic live secret key (sk_live_ + 24 chars)
LEAKY_STRIPE_KEY="sk_live_4eC39HqLyjWDarjtT1zdp7dcExAMPLE12" # ggignore: synthetic eval fixture

# Postgres — assembled into a connection URL by eval-3's setup.sh
LEAKY_DB_PASSWORD="hunter2"
