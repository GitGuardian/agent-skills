# Synthetic credential strings used by the vault-secrets eval fixtures.
# Real-shape values that ggshield's detectors flag when scanned — that is the
# point: runtime fixtures must trigger detections so the evals can grade what
# the agent does. In THIS file each line carries a `# ggignore` comment so the
# repo-wide ggshield scan (CI) stays clean; setup.sh writes the values into
# fixtures WITHOUT the ggignore comment so they detect as intended.
# None of these credentials are real.

# AWS — synthetic IAM access key pair (matches AKIA[0-9A-Z]{16})
LEAKY_AWS_KEY="AKIA2EXAMPLE7BVZSF6X" # ggignore: synthetic eval fixture
LEAKY_AWS_SECRET="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" # ggignore: synthetic eval fixture

# GitHub — synthetic classic PAT (ghp_ + 36 chars)
LEAKY_GITHUB_PAT="ghp_aB1cD2eF3gH4iJ5kL6mN7oP8qR9sT0uV1wXy" # ggignore: synthetic eval fixture

# Postgres — assembled into a connection URL by setup.sh
LEAKY_DB_PASSWORD="hunter2"
